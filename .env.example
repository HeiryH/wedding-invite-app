# Copy this to .env and fill in the values before running docker compose up

# Must be at least 32 characters — used to sign JWT tokens
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# Your domain or VPS IP (no trailing slash)
# Example: https://yourdomain.com  or  http://123.45.67.89
CORS_ORIGIN=http://localhost:3000
